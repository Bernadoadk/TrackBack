generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ShopSettings {
  id                      String          @id @default(cuid())
  shop                    String          @unique
  returnWindow            Int             @default(30)
  returnAddress           String          @default("Acme Store — Returns\n1450 Mission St, Suite 200\nSan Francisco, CA 94103\nUnited States")
  autoApprove             Boolean         @default(false)
  autoExpireDays          Int             @default(7)
  blockedSkus             String          @default("")
  notifyMerchant          Boolean         @default(true)
  fromEmail               String          @default("returns@acmestore.com")
  allowStoreCredit        Boolean         @default(true)
  allowExchanges          Boolean         @default(false)
  storeCreditBonusPercent Int             @default(10)
  incentivizeStoreCredit  Boolean         @default(false)
  brandColor              String          @default("#6C63FF")
  emailBrandColor         String          @default("#6C63FF")
  logoUrl                 String?
  returnPolicy            String          @default("We want you to love what you buy. If something isn't quite right, here's how it works:\n\n· Returns are accepted within 30 days of delivery.\n· Items must be unworn, unwashed, and in original packaging.\n· Final-sale items (marked at checkout) cannot be returned.\n· Refunds are issued to the original payment method within 3–5 business days of receiving the returned item.\n\nTo start a return, head to our return portal with your order number and email. We'll email a prepaid label and you can drop it off at any location.\n\nQuestions? Email us — we usually reply within 1 business day.")
  portalLayout            String          @default("classic")
  bannerColor             String          @default("#ffffff")
  portalStoreName         String          @default("")
  footerContact           String          @default("")
  labelFindOrder          String          @default("Find your order")
  labelSelectItems        String          @default("Select items to return")
  labelReasons            String          @default("Tell us why")
  labelRefundType         String          @default("How would you like to be refunded?")
  labelConfirm            String          @default("Review & submit")
  labelCta                String          @default("Find Order")
  labelSubmit             String          @default("Submit Return Request")
  descFindOrder           String          @default("Enter your order number and the email used at checkout.")
  descSelectItems         String          @default("Select the items you'd like to return.")
  descReasons             String          @default("Help us understand why you're returning each item.")
  descRefundType          String          @default("Choose the option that works best for you.")
  descConfirm             String          @default("One last look before we send this.")
  labelBackToStore        String          @default("Back to store")
  labelCantFind           String          @default("Can't find your order?")
  labelStartAnother       String          @default("Start another return")
  labelPoweredBy          String          @default("Secured by ReturnFlow")
  labelTrackingToggle     String          @default("Already shipped your return? Submit tracking")
  liveChatEnabled         Boolean         @default(true)
  liveChatIcon            String          @default("MessageCircle")
  onboardingCompletedAt   DateTime?
  onboardingSkippedAt     DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt
  reasons                 ReturnReason[]
  returnRequests          ReturnRequest[]
}

model ReturnReason {
  id       String       @id @default(cuid())
  shop     String
  label    String
  enabled  Boolean      @default(true)
  settings ShopSettings @relation(fields: [shop], references: [shop], onDelete: Cascade)
}

model ReturnRequest {
  id               String         @id @default(cuid())
  rma              String         @unique
  shop             String
  orderId          String
  orderName        String
  customerEmail    String
  customerName     String
  customerPhone    String?
  orderDate        DateTime
  fulfilledDate    DateTime?
  orderTotal       Float
  status           String         @default("PENDING")
  refundType       String         @default("ORIGINAL_PAYMENT")
  refundAmount     Float          @default(0)
  storeCreditBonus Float          @default(0)
  rejectionReason  String?
  exchangeNote     String?
  exchangeOrderId  String?
  exchangeOrderUrl String?
  customerId       String?
  labelUrl         String?
  trackingNumber   String?
  trackingUrl      String?
  carrier          String?
  approvedAt       DateTime?
  shippedAt        DateTime?
  receivedAt       DateTime?
  refundedAt       DateTime?
  rejectedAt       DateTime?
  refundId         String?
  storeCreditTxId  String?
  storeCreditCode  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  notes            InternalNote[]
  events           ReturnEvent[]
  items            ReturnItem[]
  settings         ShopSettings   @relation(fields: [shop], references: [shop], onDelete: Cascade)
}

model ReturnItem {
  id              String        @id @default(cuid())
  returnRequestId String
  lineItemId      String?
  productId       String
  variantId       String
  name            String
  variantName     String
  quantity        Int
  price           Float
  reason          String
  note            String?
  imageUrl        String?
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
}

model ReturnEvent {
  id              String        @id @default(cuid())
  returnRequestId String
  type            String
  source          String        @default("merchant")
  title           String
  detail          String?
  meta            String?
  createdAt       DateTime      @default(now())
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)

  @@index([returnRequestId, createdAt])
}

model InternalNote {
  id              String        @id @default(cuid())
  returnRequestId String
  author          String
  text            String
  createdAt       DateTime      @default(now())
  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String   @id @default(cuid())
  shop      String
  type      String
  subject   String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, type])
}

model Conversation {
  id                 String           @id @default(cuid())
  shop               String
  type               ConversationType
  customerEmail      String?
  customerName       String?
  unreadByMerchant   Int              @default(0)
  unreadByCustomer   Int              @default(0)
  lastMessageAt      DateTime         @default(now())
  lastMessagePreview String?          @default("")
  closed             Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  messages           ChatMessage[]

  @@unique([shop, type, customerEmail])
  @@index([shop, lastMessageAt])
}

model ChatMessage {
  id             String         @id @default(cuid())
  conversationId String
  senderType     ChatSenderType
  senderName     String?
  body           String
  readAt         DateTime?
  createdAt      DateTime       @default(now())
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model BillingSubscription {
  id              String    @id @default(cuid())
  shop            String    @unique
  plan            String    @default("free")
  shopifyChargeId String?
  status          String    @default("active")
  trialEndsAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

enum ConversationType {
  CLIENT
  SUPPORT
}

enum ChatSenderType {
  CLIENT
  MERCHANT
  SUPPORT
}
