{% comment %}
  TrackBack — Return Button block
  A customizable "Start a return" CTA. Three layout variants (banner, card,
  button), filled or outlined, optional icon, and full color/spacing control.
  All CSS is scoped to this block's instance via {{ block.id }} so it never
  collides with the host theme.
{% endcomment %}

{%- liquid
  assign uid           = block.id
  assign layout        = block.settings.layout
  assign btn_style     = block.settings.button_style
  assign btn_icon      = block.settings.button_icon
  assign alignment     = block.settings.alignment
  assign btn_color     = block.settings.button_color
  assign btn_color_15  = btn_color | color_modify: 'alpha', 0.15
  assign btn_color_45  = btn_color | color_modify: 'alpha', 0.45
  assign btn_color_08  = btn_color | color_modify: 'alpha', 0.08
-%}

<style>
  .rf-rb-{{ uid }} {
    margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;
    font-family: inherit;
    box-sizing: border-box;
    text-align: {{ alignment }};
  }
  .rf-rb-{{ uid }} *,
  .rf-rb-{{ uid }} *::before,
  .rf-rb-{{ uid }} *::after { box-sizing: border-box; }

  /* ── Banner & card share an inner shell ──────────────────────────────── */
  .rf-rb-{{ uid }}__inner {
    background: {{ block.settings.banner_bg }};
    border: 1px solid {{ block.settings.banner_border }};
    border-radius: {{ block.settings.corner_radius }}px;
    display: flex;
    gap: 16px;
  }

  /* Banner — text left, button right */
  .rf-rb-{{ uid }}--banner .rf-rb-{{ uid }}__inner {
    padding: 18px 22px;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    text-align: left;
  }

  /* Card — centered, stacked, more breathing room */
  .rf-rb-{{ uid }}--card .rf-rb-{{ uid }}__inner {
    padding: 32px 24px;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 18px;
  }
  .rf-rb-{{ uid }}--card .rf-rb-{{ uid }}__icon-circle {
    width: 52px;
    height: 52px;
    border-radius: 999px;
    background: {{ btn_color_15 }};
    color: {{ btn_color }};
    display: inline-grid;
    place-content: center;
  }
  .rf-rb-{{ uid }}--card .rf-rb-{{ uid }}__icon-circle svg {
    width: 24px; height: 24px;
  }

  /* Button-only layout — just the CTA */
  .rf-rb-{{ uid }}--button { padding: 0; }

  /* ── Text ─────────────────────────────────────────────────────────────── */
  .rf-rb-{{ uid }}__text { min-width: 0; }
  .rf-rb-{{ uid }}__title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    line-height: 1.3;
    color: {{ block.settings.text_color }};
  }
  .rf-rb-{{ uid }}__subtitle {
    margin: 4px 0 0;
    font-size: 13.5px;
    line-height: 1.45;
    color: {{ block.settings.subtitle_color }};
  }

  /* ── Button ───────────────────────────────────────────────────────────── */
  .rf-rb-{{ uid }}__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1;
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    border: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background-color 0.15s ease, color 0.15s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .rf-rb-{{ uid }}__btn svg { width: 16px; height: 16px; flex-shrink: 0; }

  /* Filled */
  .rf-rb-{{ uid }}__btn--filled {
    background: {{ btn_color }};
    color: #ffffff;
    box-shadow:
      0 1px 0 rgba(255,255,255,0.18) inset,
      0 6px 16px -4px {{ btn_color_45 }};
  }
  .rf-rb-{{ uid }}__btn--filled:hover {
    transform: translateY(-1px);
    box-shadow:
      0 1px 0 rgba(255,255,255,0.22) inset,
      0 10px 24px -6px {{ btn_color_45 }};
  }
  .rf-rb-{{ uid }}__btn--filled:active { transform: translateY(0); }

  /* Outlined */
  .rf-rb-{{ uid }}__btn--outlined {
    background: transparent;
    color: {{ btn_color }};
    border-color: {{ btn_color }};
  }
  .rf-rb-{{ uid }}__btn--outlined:hover { background: {{ btn_color_08 }}; }

  /* Focus ring (keyboard) */
  .rf-rb-{{ uid }}__btn:focus-visible {
    outline: 2px solid {{ btn_color }};
    outline-offset: 2px;
  }

  /* ── Mobile ───────────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .rf-rb-{{ uid }}--banner .rf-rb-{{ uid }}__inner {
      padding: 16px;
      flex-direction: column;
      align-items: stretch;
    }
    .rf-rb-{{ uid }}--banner .rf-rb-{{ uid }}__btn {
      justify-content: center;
      width: 100%;
    }
  }
</style>

{%- capture icon_svg -%}
  {%- case btn_icon -%}
    {%- when 'arrow' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    {%- when 'package' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
    {%- when 'refresh' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/></svg>
    {%- when 'undo' -%}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 14 4 9l5-5"/><path d="M4 9h10.5a5.5 5.5 0 0 1 5.5 5.5v0a5.5 5.5 0 0 1-5.5 5.5H11"/></svg>
  {%- endcase -%}
{%- endcapture -%}

<div class="rf-rb-{{ uid }} rf-rb-{{ uid }}--{{ layout }}" {{ block.shopify_attributes }}>
  {%- if layout == 'button' -%}
    <a href="/apps/returns"
       class="rf-rb-{{ uid }}__btn rf-rb-{{ uid }}__btn--{{ btn_style }}"
       aria-label="{{ block.settings.button_label | escape }}">
      {{ block.settings.button_label }}
      {%- if btn_icon != 'none' -%}{{ icon_svg }}{%- endif -%}
    </a>

  {%- elsif layout == 'card' -%}
    <div class="rf-rb-{{ uid }}__inner">
      {%- if btn_icon != 'none' -%}
        <div class="rf-rb-{{ uid }}__icon-circle">{{ icon_svg }}</div>
      {%- endif -%}
      <div class="rf-rb-{{ uid }}__text">
        <p class="rf-rb-{{ uid }}__title">{{ block.settings.title }}</p>
        {%- if block.settings.subtitle != blank -%}
          <p class="rf-rb-{{ uid }}__subtitle">{{ block.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      <a href="/apps/returns"
         class="rf-rb-{{ uid }}__btn rf-rb-{{ uid }}__btn--{{ btn_style }}"
         aria-label="{{ block.settings.button_label | escape }}">
        {{ block.settings.button_label }}
      </a>
    </div>

  {%- else -%}
    <div class="rf-rb-{{ uid }}__inner">
      <div class="rf-rb-{{ uid }}__text">
        <p class="rf-rb-{{ uid }}__title">{{ block.settings.title }}</p>
        {%- if block.settings.subtitle != blank -%}
          <p class="rf-rb-{{ uid }}__subtitle">{{ block.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      <a href="/apps/returns"
         class="rf-rb-{{ uid }}__btn rf-rb-{{ uid }}__btn--{{ btn_style }}"
         aria-label="{{ block.settings.button_label | escape }}">
        {{ block.settings.button_label }}
        {%- if btn_icon != 'none' -%}{{ icon_svg }}{%- endif -%}
      </a>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Return Button",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Style",
      "options": [
        { "value": "banner", "label": "Banner — title + button side-by-side" },
        { "value": "card",   "label": "Card — centered, with circular icon" },
        { "value": "button", "label": "Button only — compact CTA" }
      ],
      "default": "banner"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment (button-only)",
      "info": "Only applies to the Button-only layout.",
      "options": [
        { "value": "left",   "label": "Left"   },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right"  }
      ],
      "default": "center"
    },

    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Need to return an item?"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Start a return or exchange in just a few steps."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Start a Return"
    },

    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "filled",   "label": "Filled"   },
        { "value": "outlined", "label": "Outlined" }
      ],
      "default": "filled"
    },
    {
      "type": "select",
      "id": "button_icon",
      "label": "Button icon",
      "options": [
        { "value": "none",    "label": "None"          },
        { "value": "arrow",   "label": "Arrow →"       },
        { "value": "package", "label": "Package box"   },
        { "value": "refresh", "label": "Refresh cycle" },
        { "value": "undo",    "label": "Undo arrow"    }
      ],
      "default": "arrow"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#6C63FF"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },

    {
      "type": "header",
      "content": "Banner / card appearance"
    },
    {
      "type": "color",
      "id": "banner_bg",
      "label": "Background",
      "default": "#F5F5FF"
    },
    {
      "type": "color",
      "id": "banner_border",
      "label": "Border",
      "default": "#E0DEFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Title color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle color",
      "default": "#666666"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 10
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 16
    }
  ]
}
{% endschema %}
